# Discord application
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_oauth2_client_secret

# Target guild and bot owner (snowflake IDs)
GUILD_ID=your_guild_id
OWNER_ID=your_discord_user_id

# HTTP server (transcripts + OAuth callback)
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example.com
DISCORD_REDIRECT_URI=https://your-domain.example.com/auth/discord/callback

# SQLite database file
DATABASE_PATH=./data/tickets.sqlite

# Optional: HMAC secret for auth cookies (recommended in production)
AUTH_COOKIE_SECRET=long_random_string

# Optional: welcome DM to the user when they open a ticket (not shown in the staff channel). No leading spaces.
TICKET_WELCOME_TITLE=Support
TICKET_WELCOME_DESCRIPTION=Tell us what you need.\nPlease include any error messages.

# Typing hints: user typing → staff channel; staff typing → user DM. Set to 0 to disable. Cooldown per direction (ms).
TICKET_TYPING_HINTS=1
TICKET_TYPING_COOLDOWN_MS=8000
